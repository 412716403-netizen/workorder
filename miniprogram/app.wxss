/* Apple Human Interface 风格：浅色、大圆角、系统字体、分组列表 */

page {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Segoe UI", sans-serif;
  background-color: #f2f2f7;
  color: #000000;
  font-size: 34rpx;
  line-height: 1.35;
  -webkit-font-smoothing: antialiased;
}

/* 主按钮（填充蓝） */
.apple-btn-fill {
  width: 100%;
  margin: 0;
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.25;
  background: #007aff;
  color: #ffffff;
  border: none;
  box-sizing: border-box;
}

.apple-btn-fill::after {
  border: none;
}

.apple-btn-fill[disabled] {
  opacity: 0.45;
}

/* 次要按钮（浅灰胶囊） */
.apple-btn-muted {
  width: 100%;
  margin: 0;
  padding: 26rpx 32rpx;
  border-radius: 28rpx;
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1.25;
  background: #ffffff;
  color: #007aff;
  border: none;
  box-sizing: border-box;
}

.apple-btn-muted::after {
  border: none;
}

/* 危险操作（浅红底） */
.apple-btn-danger {
  width: 100%;
  margin: 0;
  padding: 26rpx 32rpx;
  border-radius: 28rpx;
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1.25;
  background: rgba(255, 59, 48, 0.12);
  color: #ff3b30;
  border: none;
  box-sizing: border-box;
}

.apple-btn-danger::after {
  border: none;
}

/* 小号描边按钮（如「查询」） */
.apple-btn-compact {
  margin: 0;
  padding: 18rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #e5e5ea;
  color: #007aff;
  border: none;
  flex-shrink: 0;
}

.apple-btn-compact::after {
  border: none;
}

.apple-btn-compact[disabled] {
  opacity: 0.45;
}

/* 分组容器（白底大圆角） */
.apple-group {
  background: #ffffff;
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 0 rgba(0, 0, 0, 0.04);
}

.apple-group--padded {
  padding: 32rpx 28rpx 36rpx;
}

/* 分组内行 */
.apple-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.12);
}

.apple-cell:last-child {
  border-bottom: none;
}

.apple-cell--disabled {
  opacity: 0.38;
}

.apple-cell__body {
  flex: 1;
  min-width: 0;
}

.apple-cell__title {
  font-size: 34rpx;
  font-weight: 400;
  color: #000000;
  letter-spacing: -0.02em;
}

.apple-cell__subtitle {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: rgba(60, 60, 67, 0.6);
}

.apple-chevron {
  margin-left: 16rpx;
  font-size: 44rpx;
  font-weight: 300;
  color: rgba(60, 60, 67, 0.3);
  line-height: 1;
}

/* 大标题 + 脚注 */
.apple-large-title {
  font-size: 68rpx;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #000000;
  line-height: 1.05;
}

.apple-footnote {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: rgba(60, 60, 67, 0.6);
}

.apple-section-label {
  margin: 40rpx 8rpx 12rpx 16rpx;
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(60, 60, 67, 0.6);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

/* 表单标签 */
.apple-field-label {
  display: block;
  margin: 0 0 10rpx 4rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(60, 60, 67, 0.6);
}

/* 表单输入（iOS 填充灰底） */
.apple-input {
  width: 100%;
  box-sizing: border-box;
  padding: 26rpx 28rpx;
  font-size: 34rpx;
  color: #000000;
  background: #e5e5ea;
  border-radius: 22rpx;
  border: none;
}

.apple-input-wrap {
  margin-bottom: 24rpx;
}

/* 页面水平内边距与安全区 */
.apple-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 8rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.apple-page--center {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 加载与错误 */
.apple-muted {
  text-align: center;
  padding: 120rpx 48rpx;
  font-size: 30rpx;
  color: rgba(60, 60, 67, 0.6);
}

.apple-error {
  text-align: center;
  padding: 48rpx;
  font-size: 30rpx;
  color: #ff3b30;
}

/* 状态胶囊（iOS 语义色） */
.apple-pill {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.apple-pill--pending {
  background: rgba(255, 149, 0, 0.16);
  color: #ff9500;
}

.apple-pill--approved {
  background: rgba(52, 199, 89, 0.16);
  color: #34c759;
}

.apple-pill--rejected {
  background: rgba(255, 59, 48, 0.12);
  color: #ff3b30;
}
