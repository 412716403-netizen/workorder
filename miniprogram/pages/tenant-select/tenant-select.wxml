<scroll-view class="apple-scroll" scroll-y show-scrollbar="{{false}}">
  <view class="apple-page">
    <view class="apple-large-title" style="font-size: 56rpx">选择企业</view>
    <view class="apple-footnote">轻点企业以进入；审核中或不可用的企业无法选择。</view>

    <view wx:if="{{!tenants.length}}" class="apple-muted" style="padding-top: 80rpx">暂无企业，可创建或加入企业。</view>

    <view wx:else class="apple-group" style="margin-top: 36rpx">
      <view
        wx:for="{{tenants}}"
        wx:key="id"
        wx:for-item="item"
        class="apple-cell {{item._disabled ? 'apple-cell--disabled' : ''}}"
        data-id="{{item.id}}"
        bindtap="onTapTenant"
      >
        <view class="apple-tenant-icon">{{item.name ? item.name[0] : '企'}}</view>
        <view class="apple-cell__body">
          <view class="apple-cell__title">{{item.name}}</view>
          <view class="apple-cell__subtitle">{{item._roleLabel}} · {{item._statusLabel}}</view>
        </view>
        <view wx:if="{{loadingId === item.id}}" class="apple-spinner">…</view>
        <view wx:else class="apple-chevron">›</view>
      </view>
    </view>

    <button class="apple-btn-muted" style="margin-top: 40rpx" bindtap="onOnboarding">创建新企业 / 加入其他企业</button>
    <button class="apple-btn-danger" style="margin-top: 20rpx" bindtap="onLogout">退出登录</button>
  </view>
</scroll-view>
