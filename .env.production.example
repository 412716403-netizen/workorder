# 生产环境构建前：复制为 .env.production 并改成你的 API 地址，再执行 npm run build
# cp .env.production.example .env.production
#
# 浏览器直接访问后端端口时（需在安全组放行 3001）：
# VITE_API_BASE=http://你的公网IP:3001/api
#
# 若 Nginx 已把 /api 反代到本机 3001，可用同源相对路径：
# VITE_API_BASE=/api

VITE_API_BASE=http://你的公网IP或域名:3001/api

# 设备管理 / 工序设备派工与报工选设备（构建级总开关，可选）。通常用「账号管理 → 企业管理」按企业开关即可。
# 若需整站紧急下线设备相关 UI，可设为 false（与单企业开关为「且」关系）：
# VITE_ENABLE_EQUIPMENT_FEATURES=false
