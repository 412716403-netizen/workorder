DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smarttrack_pro?schema=public"
JWT_SECRET="change-this-to-a-random-secret-key"
JWT_REFRESH_SECRET="change-this-to-another-random-secret-key"
# 长时间离开仍希望少断线时可改为 1h（需与前端静默刷新、HTTPS/Cookie 策略一并考虑）
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
# 多个前端源用逗号分隔，例如: "http://localhost:3000,http://127.0.0.1:3000"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
# 生产环境用 HTTP（未配 HTTPS）时必须为 false，否则认证 Cookie 无法保存、无法刷新令牌
# COOKIE_SECURE=false
