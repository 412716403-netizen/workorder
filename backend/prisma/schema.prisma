// ============================================================
// 11. 企业间协作
// ============================================================

model TenantCollaboration {
  id              String   @id @default(uuid()) @db.Uuid
  tenantAId       String   @map("tenant_a_id") @db.Uuid
  tenantBId       String   @map("tenant_b_id") @db.Uuid
  status          String   @default("PENDING") @db.VarChar(20)
  invitedByUserId String?  @map("invited_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  transfers   InterTenantSubcontractTransfer[]
  productMaps CollaborationProductMap[]

  @@unique([tenantAId, tenantBId])
  @@index([tenantAId])
  @@index([tenantBId])
  @@map("tenant_collaborations")
}

model InterTenantSubcontractTransfer {
  id                String   @id @default(uuid()) @db.Uuid
  collaborationId   String   @map("collaboration_id") @db.Uuid
  senderTenantId    String   @map("sender_tenant_id") @db.Uuid
  receiverTenantId  String   @map("receiver_tenant_id") @db.Uuid
  senderProductId   String   @map("sender_product_id") @db.VarChar(50)
  senderProductSku  String   @map("sender_product_sku") @db.VarChar(100)
  senderProductName String   @map("sender_product_name") @db.VarChar(200)
  status            String   @default("OPEN") @db.VarChar(20)
  aLinkMode         String   @map("a_link_mode") @db.VarChar(20)
  bReceiveMode      String?  @map("b_receive_mode") @db.VarChar(20)
  receiverProductId String?  @map("receiver_product_id") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  collaboration TenantCollaboration              @relation(fields: [collaborationId], references: [id])
  dispatches    SubcontractCollaborationDispatch[]
  returns       SubcontractCollaborationReturn[]

  @@index([senderTenantId])
  @@index([receiverTenantId])
  @@index([senderProductId])
  @@index([status])
  @@map("inter_tenant_subcontract_transfers")
}

model SubcontractCollaborationDispatch {
  id                        String   @id @default(uuid()) @db.Uuid
  transferId                String   @map("transfer_id") @db.Uuid
  status                    String   @default("PENDING") @db.VarChar(20)
  payload                   Json
  senderDispatchRecordIds   Json     @map("sender_dispatch_record_ids")
  receiverProductionOrderId String?  @map("receiver_production_order_id") @db.VarChar(50)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  transfer InterTenantSubcontractTransfer @relation(fields: [transferId], references: [id])

  @@index([transferId])
  @@index([status])
  @@map("subcontract_collaboration_dispatches")
}

model SubcontractCollaborationReturn {
  id                        String   @id @default(uuid()) @db.Uuid
  transferId                String   @map("transfer_id") @db.Uuid
  dispatchId                String?  @map("dispatch_id") @db.Uuid
  receiverProductionOrderId String?  @map("receiver_production_order_id") @db.VarChar(50)
  payload                   Json
  status                    String   @default("PENDING_A_RECEIVE") @db.VarChar(30)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  transfer InterTenantSubcontractTransfer @relation(fields: [transferId], references: [id])

  @@index([transferId])
  @@index([status])
  @@map("subcontract_collaboration_returns")
}

model CollaborationProductMap {
  id                String   @id @default(uuid()) @db.Uuid
  collaborationId   String   @map("collaboration_id") @db.Uuid
  senderSku         String   @map("sender_sku") @db.VarChar(100)
  senderProductName String   @map("sender_product_name") @db.VarChar(200)
  receiverProductId String   @map("receiver_product_id") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  collaboration TenantCollaboration @relation(fields: [collaborationId], references: [id])

  @@unique([collaborationId, senderSku])
  @@index([collaborationId])
  @@map("collaboration_product_maps")
}
