  productId          String?   @map("product_id") @db.VarChar(50)
  variantId          String?   @map("variant_id") @db.VarChar(50)
  quantity           Decimal?  @db.Decimal(12, 2)
  warehouseId        String?   @map("warehouse_id") @db.VarChar(50)
  fromWarehouseId    String?   @map("from_warehouse_id") @db.VarChar(50)
  toWarehouseId      String?   @map("to_warehouse_id") @db.VarChar(50)
  purchasePrice      Decimal?  @map("purchase_price") @db.Decimal(12, 2)
  salesPrice         Decimal?  @map("sales_price") @db.Decimal(12, 2)
  amount             Decimal?  @db.Decimal(12, 2)
  dueDate            DateTime? @map("due_date") @db.Date
