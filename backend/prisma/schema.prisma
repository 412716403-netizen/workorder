model ProductionOpRecord {
  id                              String   @id @db.VarChar(50)
  tenantId                        String   @map("tenant_id") @db.Uuid
  type                            String   @db.VarChar(20)
  orderId                         String?  @map("order_id") @db.VarChar(50)
  productId                       String   @map("product_id") @db.VarChar(50)
  variantId                       String?  @map("variant_id") @db.VarChar(50)
  quantity                        Decimal  @db.Decimal(12, 2)
  reason                          String?  @db.Text
  partner                         String?  @db.VarChar(200)
  operator                        String?  @db.VarChar(100)
  timestamp                       DateTime @db.Timestamptz()
  status                          String?  @db.VarChar(50)
  warehouseId                     String?  @map("warehouse_id") @db.VarChar(50)
  docNo                           String?  @map("doc_no") @db.VarChar(50)
  nodeId                          String?  @map("node_id") @db.VarChar(50)
  sourceNodeId                    String?  @map("source_node_id") @db.VarChar(50)
  sourceReworkId                  String?  @map("source_rework_id") @db.VarChar(50)
  reworkNodeIds                   Json?    @map("rework_node_ids")
  completedNodeIds                Json?    @map("completed_node_ids")
  reworkCompletedQuantityByNode   Json?    @map("rework_completed_quantity_by_node")
  workerId                        String?  @map("worker_id") @db.VarChar(50)
  equipmentId                     String?  @map("equipment_id") @db.VarChar(50)
  sourceProductId                 String?  @map("source_product_id") @db.VarChar(50)
  unitPrice                       Decimal? @map("unit_price") @db.Decimal(12, 2)
  amount                          Decimal? @db.Decimal(12, 2)
  collabData                      Json?    @map("collab_data")
  createdAt                       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  updatedAt                       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  productionOrder ProductionOrder? @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([orderId])
  @@index([productId])
  @@index([timestamp])
  @@index([docNo])
  @@map("production_op_records")
}

