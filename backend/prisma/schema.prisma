generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. 用户与认证
// ============================================================

model User {
  id               String    @id @default(uuid()) @db.Uuid
  username         String    @unique @db.VarChar(50)
  phone            String?   @unique @db.VarChar(20)
  email            String?   @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  displayName      String?   @map("display_name") @db.VarChar(100)
  role             String    @default("user") @db.VarChar(20)
  status           String    @default("active") @db.VarChar(20)
  isEnterprise     Boolean   @default(false) @map("is_enterprise")
  accountExpiresAt DateTime? @map("account_expires_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  refreshTokens    RefreshToken[]
  memberships      TenantMembership[]
  joinApplications JoinApplication[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.Text
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================================
// 1b. 企业（租户）与成员
// ============================================================

model Tenant {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.VarChar(200)
  logo       String?   @db.Text
  inviteCode String    @unique @map("invite_code") @db.VarChar(50)
  status     String    @default("active") @db.VarChar(20)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  memberships      TenantMembership[]
  joinApplications JoinApplication[]

  @@map("tenants")
}

model TenantMembership {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  role                 String   @default("worker") @db.VarChar(20)
  permissions          Json     @default("[]")
  roleId               String?  @map("role_id") @db.VarChar(50)
  assignedMilestoneIds Json     @default("[]") @map("assigned_milestone_ids")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole Role?  @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, tenantId])
  @@map("tenant_memberships")
}

model Role {
  id          String   @id @db.VarChar(50)
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  permissions Json     @default("[]")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  members TenantMembership[]

  @@index([tenantId])
  @@map("roles")
}

model JoinApplication {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  status     String    @default("PENDING") @db.VarChar(20)
  message    String?   @db.Text
  reviewedBy String?   @map("reviewed_by") @db.Uuid
  reviewedAt DateTime? @map("reviewed_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("join_applications")
}

// ============================================================
// 2. 系统设置与配置
// ============================================================

model ProductCategory {
  id                 String   @id @db.VarChar(50)
  tenantId           String   @map("tenant_id") @db.Uuid
  name               String   @db.VarChar(100)
  color              String?  @db.VarChar(20)
  hasProcess         Boolean  @default(false) @map("has_process")
  hasSalesPrice      Boolean  @default(false) @map("has_sales_price")
  hasPurchasePrice   Boolean  @default(false) @map("has_purchase_price")
  hasColorSize       Boolean  @default(false) @map("has_color_size")
  hasBatchManagement Boolean  @default(false) @map("has_batch_management")
  customFields       Json     @default("[]") @map("custom_fields")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  products Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model PartnerCategory {
  id           String   @id @db.VarChar(50)
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(100)
  description  String?  @db.Text
  customFields Json     @default("[]") @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  partners Partner[]

  @@index([tenantId])
  @@map("partner_categories")
}

model GlobalNodeTemplate {
  id                        String   @id @db.VarChar(50)
  tenantId                  String   @map("tenant_id") @db.Uuid
  name                      String   @db.VarChar(100)
  reportTemplate            Json     @default("[]") @map("report_template")
  hasBom                    Boolean  @default(false) @map("has_bom")
  category                  String?  @db.VarChar(50)
  enableWorkerAssignment    Boolean  @default(false) @map("enable_worker_assignment")
  enableEquipmentAssignment Boolean  @default(false) @map("enable_equipment_assignment")
  enableEquipmentOnReport   Boolean  @default(false) @map("enable_equipment_on_report")
  enablePieceRate           Boolean  @default(false) @map("enable_piece_rate")
  allowOutsource            Boolean  @default(false) @map("allow_outsource")
  sortOrder                 Int      @default(0) @map("sort_order")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId])
  @@map("global_node_templates")
}

model Warehouse {
  id          String   @id @db.VarChar(50)
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  code        String?  @db.VarChar(50)
  category    String?  @db.VarChar(50)
  location    String?  @db.VarChar(200)
  contact     String?  @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId])
  @@map("warehouses")
}

model FinanceCategory {
  id                   String   @id @db.VarChar(50)
  tenantId             String   @map("tenant_id") @db.Uuid
  kind                 String   @db.VarChar(10)
  name                 String   @db.VarChar(100)
  linkOrder            Boolean  @default(false) @map("link_order")
  linkPartner          Boolean  @default(false) @map("link_partner")
  selectPaymentAccount Boolean  @default(false) @map("select_payment_account")
  linkWorker           Boolean  @default(false) @map("link_worker")
  linkProduct          Boolean  @default(false) @map("link_product")
  customFields         Json     @default("[]") @map("custom_fields")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  financeRecords FinanceRecord[]

  @@index([tenantId])
  @@map("finance_categories")
}

model FinanceAccountType {
  id        String   @id @db.VarChar(50)
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId])
  @@map("finance_account_types")
}

model DictionaryItem {
  id        String   @id @db.VarChar(50)
  tenantId  String   @map("tenant_id") @db.Uuid
  type      String   @db.VarChar(20)
  name      String   @db.VarChar(100)
  value     String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId])
  @@index([type])
  @@map("dictionary_items")
}

model SystemSetting {
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String   @db.VarChar(100)
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@id([tenantId, key])
  @@map("system_settings")
}

// ============================================================
// 3. 基础主数据
// ============================================================

model Partner {
  id         String   @id @db.VarChar(50)
  tenantId   String   @map("tenant_id") @db.Uuid
  name       String   @db.VarChar(200)
  categoryId String?  @map("category_id") @db.VarChar(50)
  contact               String?  @db.VarChar(200)
  customData            Json     @default("{}") @map("custom_data")
  collaborationTenantId String?  @map("collaboration_tenant_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  category PartnerCategory? @relation(fields: [categoryId], references: [id])

  @@index([tenantId])
  @@index([categoryId])
  @@map("partners")
}

model Worker {
  id                   String   @id @db.VarChar(50)
  tenantId             String   @map("tenant_id") @db.Uuid
  name                 String   @db.VarChar(100)
  groupName            String?  @map("group_name") @db.VarChar(50)
  role                 String?  @db.VarChar(50)
  status               String   @default("ACTIVE") @db.VarChar(20)
  skills               Json     @default("[]")
  assignedMilestoneIds Json     @default("[]") @map("assigned_milestone_ids")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId])
  @@map("workers")
}

model Equipment {
  id                   String   @id @db.VarChar(50)
  tenantId             String   @map("tenant_id") @db.Uuid
  name                 String   @db.VarChar(100)
  code                 String?  @db.VarChar(50)
  assignedMilestoneIds Json     @default("[]") @map("assigned_milestone_ids")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId])
  @@map("equipment")
}

model Product {
  id                 String   @id @db.VarChar(50)
  tenantId           String   @map("tenant_id") @db.Uuid
  sku                String   @db.VarChar(100)
  name               String   @db.VarChar(200)
  description        String?  @db.Text
  imageUrl           String?  @map("image_url") @db.Text
  categoryId         String?  @map("category_id") @db.VarChar(50)
  salesPrice         Decimal? @map("sales_price") @db.Decimal(12, 2)
  purchasePrice      Decimal? @map("purchase_price") @db.Decimal(12, 2)
  supplierId         String?  @map("supplier_id") @db.VarChar(50)
  unitId             String?  @map("unit_id") @db.VarChar(50)
  colorIds           Json     @default("[]") @map("color_ids")
  sizeIds            Json     @default("[]") @map("size_ids")
  categoryCustomData Json     @default("{}") @map("category_custom_data")
  milestoneNodeIds   Json     @default("[]") @map("milestone_node_ids")
  nodeRates          Json     @default("{}") @map("node_rates")
  nodePricingModes   Json     @default("{}") @map("node_pricing_modes")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  boms     Bom[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([sku])
  @@map("products")
}

model ProductVariant {
  id        String   @id @db.VarChar(50)
  productId String   @map("product_id") @db.VarChar(50)
  colorId   String?  @map("color_id") @db.VarChar(50)
  sizeId    String?  @map("size_id") @db.VarChar(50)
  skuSuffix String?  @map("sku_suffix") @db.VarChar(50)
  nodeBoms  Json     @default("{}") @map("node_boms")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Bom {
  id              String   @id @db.VarChar(50)
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String   @db.VarChar(200)
  parentProductId String   @map("parent_product_id") @db.VarChar(50)
  variantId       String?  @map("variant_id") @db.VarChar(50)
  nodeId          String?  @map("node_id") @db.VarChar(50)
  version         String?  @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  parentProduct Product   @relation(fields: [parentProductId], references: [id])
  items         BomItem[]

  @@index([tenantId])
  @@index([parentProductId])
  @@map("boms")
}

model BomItem {
  id              Int      @id @default(autoincrement())
  bomId           String   @map("bom_id") @db.VarChar(50)
  categoryId      String?  @map("category_id") @db.VarChar(50)
  productId       String   @map("product_id") @db.VarChar(50)
  quantity        Decimal  @db.Decimal(12, 4)
  note            String?  @db.Text
  useShortageOnly Boolean  @default(false) @map("use_shortage_only")
  sortOrder       Int      @default(0) @map("sort_order")

  bom Bom @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([bomId])
  @@map("bom_items")
}

// ============================================================
// 4. 生产计划
// ============================================================

model PlanOrder {
  id               String    @id @db.VarChar(50)
  tenantId         String    @map("tenant_id") @db.Uuid
  planNumber       String    @map("plan_number") @db.VarChar(50)
  parentPlanId     String?   @map("parent_plan_id") @db.VarChar(50)
  bomNodeId        String?   @map("bom_node_id") @db.VarChar(50)
  productId        String    @map("product_id") @db.VarChar(50)
  startDate        DateTime? @map("start_date") @db.Date
  dueDate          DateTime? @map("due_date") @db.Date
  status           String    @default("DRAFT") @db.VarChar(20)
  customer         String?   @db.VarChar(200)
  priority         String    @default("Medium") @db.VarChar(10)
  assignments      Json      @default("{}")
  customData       Json      @default("{}") @map("custom_data")
  nodePricingModes Json?     @map("node_pricing_modes")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  parentPlan       PlanOrder?        @relation("PlanHierarchy", fields: [parentPlanId], references: [id])
  childPlans       PlanOrder[]       @relation("PlanHierarchy")
  items            PlanItem[]
  productionOrders ProductionOrder[]

  @@unique([tenantId, planNumber])
  @@index([tenantId])
  @@index([parentPlanId])
  @@index([productId])
  @@index([status])
  @@map("plan_orders")
}

model PlanItem {
  id          Int     @id @default(autoincrement())
  planOrderId String  @map("plan_order_id") @db.VarChar(50)
  variantId   String? @map("variant_id") @db.VarChar(50)
  quantity    Decimal @db.Decimal(12, 2)

  planOrder PlanOrder @relation(fields: [planOrderId], references: [id], onDelete: Cascade)

  @@index([planOrderId])
  @@map("plan_items")
}

// ============================================================
// 5. 生产工单
// ============================================================

model ProductionOrder {
  id            String    @id @db.VarChar(50)
  tenantId      String    @map("tenant_id") @db.Uuid
  orderNumber   String    @map("order_number") @db.VarChar(50)
  planOrderId   String?   @map("plan_order_id") @db.VarChar(50)
  parentOrderId String?   @map("parent_order_id") @db.VarChar(50)
  bomNodeId     String?   @map("bom_node_id") @db.VarChar(50)
  sourcePlanId  String?   @map("source_plan_id") @db.VarChar(50)
  productId     String    @map("product_id") @db.VarChar(50)
  productName   String?   @map("product_name") @db.VarChar(200)
  sku           String?   @db.VarChar(100)
  customer      String?   @db.VarChar(200)
  startDate     DateTime? @map("start_date") @db.Date
  dueDate       DateTime? @map("due_date") @db.Date
  status        String    @default("PLANNING") @db.VarChar(20)
  priority      String    @default("Medium") @db.VarChar(10)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  planOrder    PlanOrder?        @relation(fields: [planOrderId], references: [id])
  parentOrder  ProductionOrder?  @relation("OrderHierarchy", fields: [parentOrderId], references: [id])
  childOrders  ProductionOrder[] @relation("OrderHierarchy")
  items        OrderItem[]
  milestones   Milestone[]
  opRecords    ProductionOpRecord[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([parentOrderId])
  @@index([productId])
  @@index([status])
  @@map("production_orders")
}

model OrderItem {
  id                Int     @id @default(autoincrement())
  productionOrderId String  @map("production_order_id") @db.VarChar(50)
  variantId         String? @map("variant_id") @db.VarChar(50)
  quantity          Decimal @db.Decimal(12, 2)
  completedQuantity Decimal @default(0) @map("completed_quantity") @db.Decimal(12, 2)

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@map("order_items")
}

model Milestone {
  id                   String    @id @db.VarChar(50)
  productionOrderId    String    @map("production_order_id") @db.VarChar(50)
  templateId           String    @map("template_id") @db.VarChar(50)
  name                 String    @db.VarChar(100)
  status               String    @default("PENDING") @db.VarChar(20)
  plannedDate          DateTime? @map("planned_date") @db.Date
  actualDate           DateTime? @map("actual_date") @db.Date
  completedQuantity    Decimal   @default(0) @map("completed_quantity") @db.Decimal(12, 2)
  reportTemplate       Json      @default("[]") @map("report_template")
  weight               Decimal   @default(1) @db.Decimal(5, 2)
  assignedWorkerIds    Json      @default("[]") @map("assigned_worker_ids")
  assignedEquipmentIds Json      @default("[]") @map("assigned_equipment_ids")
  sortOrder            Int       @default(0) @map("sort_order")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  productionOrder ProductionOrder  @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  reports         MilestoneReport[]

  @@index([productionOrderId])
  @@index([templateId])
  @@map("milestones")
}

model MilestoneReport {
  id                String   @id @db.VarChar(50)
  milestoneId       String   @map("milestone_id") @db.VarChar(50)
  timestamp         DateTime @db.Timestamptz()
  operator          String?  @db.VarChar(100)
  quantity          Decimal  @db.Decimal(12, 2)
  defectiveQuantity Decimal  @default(0) @map("defective_quantity") @db.Decimal(12, 2)
  equipmentId       String?  @map("equipment_id") @db.VarChar(50)
  variantId         String?  @map("variant_id") @db.VarChar(50)
  reportBatchId     String?  @map("report_batch_id") @db.VarChar(50)
  reportNo          String?  @map("report_no") @db.VarChar(50)
  customData        Json     @default("{}") @map("custom_data")
  notes             String?  @db.Text
  rate              Decimal? @db.Decimal(12, 2)
  workerId          String?  @map("worker_id") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
  @@index([reportBatchId])
  @@index([workerId])
  @@index([reportNo])
  @@map("milestone_reports")
}

// ============================================================
// 6. 产品工序进度（关联产品模式）
// ============================================================

model ProductMilestoneProgress {
  id                    String   @id @db.VarChar(50)
  tenantId              String   @map("tenant_id") @db.Uuid
  productId             String   @map("product_id") @db.VarChar(50)
  variantId             String?  @map("variant_id") @db.VarChar(50)
  milestoneTemplateId   String   @map("milestone_template_id") @db.VarChar(50)
  completedQuantity     Decimal  @default(0) @map("completed_quantity") @db.Decimal(12, 2)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  reports ProductProgressReport[]

  @@unique([productId, variantId, milestoneTemplateId], map: "idx_pmp_unique")
  @@index([tenantId])
  @@index([productId])
  @@map("product_milestone_progresses")
}

model ProductProgressReport {
  id                String   @id @db.VarChar(50)
  progressId        String   @map("progress_id") @db.VarChar(50)
  timestamp         DateTime @db.Timestamptz()
  operator          String?  @db.VarChar(100)
  quantity          Decimal  @db.Decimal(12, 2)
  defectiveQuantity Decimal  @default(0) @map("defective_quantity") @db.Decimal(12, 2)
  equipmentId       String?  @map("equipment_id") @db.VarChar(50)
  variantId         String?  @map("variant_id") @db.VarChar(50)
  reportBatchId     String?  @map("report_batch_id") @db.VarChar(50)
  reportNo          String?  @map("report_no") @db.VarChar(50)
  customData        Json     @default("{}") @map("custom_data")
  notes             String?  @db.Text
  rate              Decimal? @db.Decimal(12, 2)
  workerId          String?  @map("worker_id") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  progress ProductMilestoneProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@index([progressId])
  @@index([reportBatchId])
  @@index([reportNo])
  @@map("product_progress_reports")
}

